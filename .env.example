# Copy to .env.local and fill in real values. Do not commit secrets.

MONGODB_URI=

# Cloudinary — required for project image uploads
# https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Watermark sticker auto-uploads to Cloudinary as brand/lumaro-watermark
# on the first /api/houseprojects request (from public/brand/lumaro-watermark-sticker.png).
# Set true to force re-upload/replace it:
# WATERMARK_FORCE_UPLOAD=true

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Transactional email (Nodemailer)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true

# Google OAuth — same Client ID for server and browser
# https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# Public site URL (used by sitemap.xml)
NEXT_PUBLIC_SITE_URL=https://lumaronexus.com

# Google Analytics 4 — Measurement ID from analytics.google.com (looks like G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Cloudflare Turnstile (bot / human check on public forms)
# Dashboard: https://dash.cloudflare.com/ → Turnstile → Add widget
# Site key is public (browser); secret key stays on the server only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional local testing keys from Cloudflare docs (always pass):
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
