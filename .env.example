# Copy to .env.local and fill in real values. Do not commit secrets.

MONGODB_URI=

# Cloudinary — required for project image uploads
# https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Transactional email (Nodemailer)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true

# Google OAuth — same Client ID for server and browser
# https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
